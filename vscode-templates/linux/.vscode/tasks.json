// =============================================================================
// JaszczurHAL VS Code tasks template (Linux / macOS / WSL).
//
// How to use:
//   1. Copy this whole `.vscode/` directory into your project root.
//   2. Adjust task labels / commands / shortcuts to fit your workflow.
//   3. Most tasks delegate to ${workspaceFolder}/scripts/* — edit those
//      scripts if you need project-specific behavior instead of touching
//      this file.
//   4. Keep the "inputs" array in sync with any `${input:*}` references
//      below — VS Code resolves these interactively.
//
// Key design notes:
//   - Build / Debug / Upload all delegate to scripts/build.sh.
//     Swap it for your own entry point if you need a different flow.
//   - "Upload" starts the persistent serial monitor in the background so
//     log output is visible immediately after re-enumeration.
//   - "Change port" (Ctrl+Shift+9) only edits settings.json — the
//     persistent monitor re-reads the setting while running, so the new
//     port takes effect without restarting the monitor.
// =============================================================================
{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "boardChoice",
            "description": "Select target board",
            "type": "pickString",
            "options": [
                "rp2040:rp2040:rpipico          — Raspberry Pi Pico",
                "rp2040:rp2040:rpipicow         — Raspberry Pi Pico W",
                "rp2040:rp2040:rpipico2         — Raspberry Pi Pico 2",
                "rp2040:rp2040:rpipico2w        — Raspberry Pi Pico 2 W",
                "rp2040:rp2040:waveshare_rp2040_zero — Waveshare RP2040-Zero",
                "rp2040:rp2040:waveshare_rp2040_plus — Waveshare RP2040-Plus"
            ],
            "default": "rp2040:rp2040:rpipico          — Raspberry Pi Pico"
        },
        {
            "id": "libraryName",
            "description": "Library name (e.g. 'Adafruit MCP9600')",
            "type": "promptString",
            "default": ""
        },
        {
            "id": "uploadPort",
            "description": "Serial port (e.g. /dev/ttyACM0)",
            "type": "promptString",
            "default": "/dev/ttyACM0"
        }
    ],
    "tasks": [
        {
            "label": "Build",
            "detail": "Ctrl+Shift+1 — compile sketch",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/build.sh",
            "args": ["build"],
            "group": { "kind": "build", "isDefault": true },
            "presentation": {
                "echo": true, "reveal": "always", "focus": false,
                "panel": "shared", "showReuseMessage": false, "clear": true
            },
            "problemMatcher": {
                "owner": "arduino",
                "fileLocation": ["autoDetect", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^(.+):(\\d+):(\\d+):\\s+(warning|error):\\s+(.+)$",
                    "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5
                }
            }
        },
        {
            "label": "Build (Debug)",
            "detail": "Compile with debug symbols (auto-run by F5)",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/build.sh",
            "args": ["debug"],
            "group": "build",
            "presentation": {
                "echo": true, "reveal": "always", "focus": false,
                "panel": "shared", "showReuseMessage": false, "clear": true
            },
            "problemMatcher": {
                "owner": "arduino",
                "fileLocation": ["autoDetect", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^(.+):(\\d+):(\\d+):\\s+(warning|error):\\s+(.+)$",
                    "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5
                }
            }
        },
        {
            "label": "Upload",
            "detail": "Ctrl+Shift+2 — start persistent monitor (if needed) + compile + upload",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/build.sh",
            "args": ["upload"],
            "presentation": {
                "echo": true, "reveal": "always", "focus": false,
                "panel": "shared", "showReuseMessage": false, "clear": true
            },
            "problemMatcher": {
                "owner": "arduino",
                "fileLocation": ["autoDetect", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^(.+):(\\d+):(\\d+):\\s+(warning|error):\\s+(.+)$",
                    "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5
                }
            }
        },
        {
            "label": "Upload (UF2 / BOOTSEL)",
            "detail": "Ctrl+Shift+4 — compile + copy UF2 to BOOTSEL drive",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/upload-uf2.sh",
            "presentation": {
                "echo": true, "reveal": "always", "focus": true,
                "panel": "shared", "showReuseMessage": false, "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Monitor (persistent)",
            "detail": "Ctrl+Shift+3 — auto-reconnecting monitor; re-reads the preferred port while running",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/scripts/serial-persistent.py",
                "--project-dir", "${workspaceFolder}",
                "-m", "pico"
            ],
            "presentation": {
                "echo": true, "reveal": "always", "focus": true,
                "panel": "dedicated", "showReuseMessage": false
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Monitor (Debug Probe)",
            "detail": "Ctrl+Shift+5 — monitor for Raspberry Pi Debug Probe / Picoprobe",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/scripts/serial-persistent.py",
                "--project-dir", "${workspaceFolder}",
                "-m", "probe"
            ],
            "presentation": {
                "echo": true, "reveal": "always", "focus": true,
                "panel": "dedicated", "showReuseMessage": false
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Monitor (any port)",
            "detail": "Monitor any /dev/ttyACM* or /dev/ttyUSB* device",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/scripts/serial-persistent.py",
                "--project-dir", "${workspaceFolder}",
                "-m", "any"
            ],
            "presentation": {
                "echo": true, "reveal": "always", "focus": true,
                "panel": "dedicated", "showReuseMessage": false
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Select board (GUI)",
            "detail": "Ctrl+Shift+Alt+1 — quick selection from VS Code dropdown",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "SELECTION='${input:boardChoice}'; FQBN=$(echo \"$SELECTION\" | sed 's/ *—.*//'); FQBN=$(echo $FQBN | xargs); DESC=$(echo \"$SELECTION\" | sed 's/.*— *//'); echo \"Setting board: $DESC\"; echo \"FQBN: $FQBN\"; python3 -c \"import json; f='${workspaceFolder}/.vscode/settings.json'; s=json.load(open(f)); s['arduino.fqbn']='$FQBN'; s['arduino.boardDescription']='$DESC'; json.dump(s,open(f,'w'),indent=4); print('\\nOK: settings.json updated'); print('Run: Refresh IntelliSense')\""
            ],
            "presentation": {
                "echo": true, "reveal": "always", "focus": false,
                "panel": "shared", "showReuseMessage": false, "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Select board (interactive)",
            "detail": "Ctrl+Shift+Alt+2 — full menu with advanced options (flash, freq, USB, debug)",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/select-board.sh",
            "presentation": {
                "echo": true, "reveal": "always", "focus": true,
                "panel": "shared", "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "Refresh IntelliSense",
            "detail": "Ctrl+Shift+6 — compile project and regenerate c_cpp_properties.json",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/refresh-intellisense.sh",
            "presentation": {
                "echo": true, "reveal": "always", "focus": false,
                "panel": "shared", "showReuseMessage": false, "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Install library",
            "detail": "Ctrl+Shift+0 — install library via arduino-cli",
            "type": "shell",
            "command": "${config:arduino.cliPath}",
            "args": ["lib", "install", "${input:libraryName}"],
            "presentation": {
                "echo": true, "reveal": "always", "focus": true,
                "panel": "shared", "showReuseMessage": false, "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "detail": "Ctrl+Shift+7 — remove .build directory",
            "type": "shell",
            "command": "rm",
            "args": ["-rf", "${workspaceFolder}/.build"],
            "presentation": {
                "echo": true, "reveal": "silent",
                "panel": "shared", "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "List ports",
            "detail": "Ctrl+Shift+8 — list connected Arduino devices",
            "type": "shell",
            "command": "${config:arduino.cliPath}",
            "args": ["board", "list"],
            "presentation": {
                "echo": true, "reveal": "always", "focus": false,
                "panel": "shared", "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "Change port",
            "detail": "Ctrl+Shift+9 — set upload port in settings.json (persistent monitor picks this up without restart)",
            "type": "shell",
            "command": "python3",
            "args": [
                "-c",
                "import json, sys; f = sys.argv[1]; port = sys.argv[2]; s = json.load(open(f)); s[\"arduino.uploadPort\"] = port; json.dump(s, open(f, \"w\"), indent=4); print(\"Port set to: \" + port)",
                "${workspaceFolder}/.vscode/settings.json",
                "${input:uploadPort}"
            ],
            "presentation": {
                "echo": true, "reveal": "always", "focus": false,
                "panel": "shared", "showReuseMessage": false
            },
            "problemMatcher": []
        }
    ]
}
