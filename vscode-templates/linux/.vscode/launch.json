// =============================================================================
// Cortex-Debug launch configurations for RP2040 / RP2350 via Raspberry Pi
// Debug Probe (CMSIS-DAP). See `linux/README.md` → "Debugging with Raspberry
// Pi Debug Probe" for SWD wiring, probe firmware requirements, and the set
// of `cortex-debug.*` paths you need in `.vscode/settings.json`.
//
// Targets (adjust `device` and `configFiles` to your board):
//   - Debug: RP2040 (Pico / Pico W / Zero / Plus) — launch: flash + break at main
//   - Debug: RP2350 (Pico 2 / Pico 2 W)          — launch: flash + break at main
//   - Debug: Attach RP2040 / RP2350              — attach without re-flashing
//
// Preconditions:
//   1. Raspberry Pi Debug Probe connected to target SWD pins (SWCLK, SWDIO, GND).
//   2. `marus25.cortex-debug` VS Code extension installed (recommendations.json).
//   3. `cortex-debug.openocdPath`, `cortex-debug.gdbPath`,
//      `cortex-debug.openocdScriptsPath`, `cortex-debug.svdFileRP2040`, and
//      `cortex-debug.svdFileRP2350` set in `.vscode/settings.json`
//      (openocd and arm-none-eabi-gdb ship with the arduino-pico core —
//      see settings.json comments for the exact paths).
//   4. For the `launch` configurations, the pre-launch task
//      "Build (Debug)" produces an ELF at
//      `${workspaceFolder}/.build/${workspaceFolderBasename}.ino.elf`.
// =============================================================================
{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: RP2040 (Pico/Pico W/Zero/Plus)",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceFolder}/.build/${workspaceFolderBasename}.ino.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "serverpath": "${config:cortex-debug.openocdPath}",
            "gdbPath": "${config:cortex-debug.gdbPath}",
            "device": "RP2040",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2040.cfg"
            ],
            "searchDir": [
                "${config:cortex-debug.openocdScriptsPath}"
            ],
            "svdFile": "${config:cortex-debug.svdFileRP2040}",
            "openOCDLaunchCommands": [
                "adapter speed 5000"
            ],
            "runToEntryPoint": "main",
            "postRestartCommands": [
                "break main",
                "continue"
            ],
            "preLaunchTask": "Build (Debug)",
            "showDevDebugOutput": "parsed",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        },
        {
            "name": "Debug: RP2350 (Pico 2/Pico 2W)",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceFolder}/.build/${workspaceFolderBasename}.ino.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "serverpath": "${config:cortex-debug.openocdPath}",
            "gdbPath": "${config:cortex-debug.gdbPath}",
            "device": "RP2350",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2350.cfg"
            ],
            "searchDir": [
                "${config:cortex-debug.openocdScriptsPath}"
            ],
            "svdFile": "${config:cortex-debug.svdFileRP2350}",
            "openOCDLaunchCommands": [
                "adapter speed 5000"
            ],
            "runToEntryPoint": "main",
            "postRestartCommands": [
                "break main",
                "continue"
            ],
            "preLaunchTask": "Build (Debug)",
            "showDevDebugOutput": "parsed",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        },
        {
            "name": "Debug: Attach RP2040 (no upload)",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceFolder}/.build/${workspaceFolderBasename}.ino.elf",
            "request": "attach",
            "type": "cortex-debug",
            "servertype": "openocd",
            "serverpath": "${config:cortex-debug.openocdPath}",
            "gdbPath": "${config:cortex-debug.gdbPath}",
            "device": "RP2040",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2040.cfg"
            ],
            "searchDir": [
                "${config:cortex-debug.openocdScriptsPath}"
            ],
            "svdFile": "${config:cortex-debug.svdFileRP2040}",
            "openOCDLaunchCommands": [
                "adapter speed 5000"
            ],
            "showDevDebugOutput": "parsed",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        },
        {
            "name": "Debug: Attach RP2350 (no upload)",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceFolder}/.build/${workspaceFolderBasename}.ino.elf",
            "request": "attach",
            "type": "cortex-debug",
            "servertype": "openocd",
            "serverpath": "${config:cortex-debug.openocdPath}",
            "gdbPath": "${config:cortex-debug.gdbPath}",
            "device": "RP2350",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2350.cfg"
            ],
            "searchDir": [
                "${config:cortex-debug.openocdScriptsPath}"
            ],
            "svdFile": "${config:cortex-debug.svdFileRP2350}",
            "openOCDLaunchCommands": [
                "adapter speed 5000"
            ],
            "showDevDebugOutput": "parsed",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        }
    ]
}
